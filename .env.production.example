# ─── Production environment — скопируйте в .env.production на сервере ───

# PostgreSQL (REG.RU или свой сервер)
DATABASE_URL="postgresql://errani_user:ПАРОЛЬ@localhost:5432/errani_db?schema=public"

# JWT — обязательно смените на случайную строку!
JWT_SECRET="замените-на-случайную-строку-минимум-32-символа"

# Данные администратора
ADMIN_EMAIL="admin@errani.ru"
ADMIN_PASSWORD="замените-на-надёжный-пароль"

# URL сайта
NEXT_PUBLIC_SITE_URL="https://errani.ru"

# YuKassa
YUKASSA_SHOP_ID=""
YUKASSA_SECRET_KEY=""

# Stripe
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
