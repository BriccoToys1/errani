generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String   @default("Admin")
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String   @default("")
  country   String   @default("RU")
  city      String   @default("")
  zipCode   String   @default("")
  street    String   @default("")
  house     String   @default("")
  apartment String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  favorites Favorite[]
}

model Product {
  id            String         @id @default(uuid())
  name          String
  nameRu        String?        // Russian name
  slug          String         @unique
  description   String
  descriptionRu String?        // Russian description
  price         Float
  oldPrice      Float?         // Original price (for discount display)
  discount      Int            @default(0) // Discount percentage 0-100
  currency      String         @default("RUB")
  image         String
  images        String         @default("[]") // JSON array of image URLs
  stock         Int            @default(0) // Quantity in stock
  inStock       Boolean        @default(true)
  isPreorder    Boolean        @default(false)
  isHit         Boolean        @default(false)
  isAuthor      Boolean        @default(false) // авторская колода
  isActive      Boolean        @default(true) // Show in catalog
  avitoUrl      String         @default("") // link to avito listing if parsed
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orderItems    OrderItem[]
  favorites     Favorite[]
  avitoProducts AvitoProduct[]
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  customerName    String
  customerEmail   String
  customerPhone   String      @default("")
  country         String      @default("RU")
  city            String      @default("")
  zipCode         String      @default("")
  street          String      @default("")
  house           String      @default("")
  apartment       String      @default("")
  shippingMethod  String      @default("") // ozon, yandex, pochta_ru, cdek, pochta_int
  status          String      @default("assembling") // assembling, shipped, in_transit, delivered, cancelled
  paymentMethod   String      @default("") // yukassa, stripe, apple_pay, google_pay
  paymentId       String      @default("")
  totalAmount     Float
  currency        String      @default("RUB")
  notes           String      @default("")
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model SiteContent {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   // JSON content
  updatedAt DateTime @updatedAt
}

// ─── Analytics ───

model PageView {
  id        String   @id @default(uuid())
  sessionId String
  path      String
  referrer  String   @default("")
  userAgent String   @default("")
  ip        String   @default("")
  country   String   @default("")
  city      String   @default("")
  lang      String   @default("")
  duration  Int      @default(0)  // seconds on page
  createdAt DateTime @default(now())
}

model DailyStat {
  id         String   @id @default(uuid())
  date       String   @unique  // YYYY-MM-DD
  views      Int      @default(0)
  visitors   Int      @default(0)
  orders     Int      @default(0)
  revenue    Float    @default(0)
  createdAt  DateTime @default(now())
}

// ─── Inquiries / Contact Form ───

model Inquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String   @default("")
  message   String
  status    String   @default("new") // new, read, replied, closed
  notes     String   @default("")
  source    String   @default("contact_form") // contact_form, avito, email, etc.
  ip        String   @default("")
  userAgent String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Avito Integration ───

model AvitoProduct {
  id          String   @id @default(uuid())
  avitoId     String   @unique
  title       String
  price       Float
  currency    String   @default("RUB")
  description String
  images      String   @default("[]") // JSON array
  category    String   @default("")
  status      String   @default("active") // active, sold, inactive
  syncedAt    DateTime @default(now())
  productId   String?  // linked local product
  product     Product? @relation(fields: [productId], references: [id])
  rawData     String   @default("{}") // full JSON from Avito
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
